# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY_SECRET=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# Robinhood Credentials
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_TOTP_SEED=

# E*TRADE Credentials
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_OAUTH_TOKEN=
ETRADE_OAUTH_SECRET=

# IBKR Credentials
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Enabled Brokers (comma-separated)
ENABLED_BROKERS=robinhood,etrade,ibkr


# Account identification (triggers real provider instead of stub)
#IBKR_ACCOUNT_ID=DU123456    # Your paper/live account ID

# Safety
IBKR_READONLY=true           # Start read-only, change to false when ready

# Market data
IBKR_MARKET_DATA_TYPE=1      # 4=delayed(free), 3=frozen, 1=live(paid subscription)

# Timeout
IBKR_CONNECT_TIMEOUT=30      # seconds
